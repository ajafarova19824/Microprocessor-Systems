#include <avr/io.h>
#include <util/delay.h>

void SPI_MasterInit(void) {
    // MOSI, SCK, SS as outputs; MISO is input
    DDRB |= (1 << PB3) | (1 << PB5) | (1 << PB2);
    // SS high (deselect slave) initially
    PORTB |= (1 << PB2);

    // SPE=1, MSTR=1, SPR0=1 → fosc/16 = 1 MHz, Mode 0
    SPCR = (1 << SPE) | (1 << MSTR) | (1 << SPR0);
}

void SPI_Transmit(uint8_t data) {
    PORTB &= ~(1 << PB2);   // SS LOW — select slave
    SPDR = data;             // load byte → starts transmission
    while (!(SPSR & (1 << SPIF)));  // wait for SPIF flag
    PORTB |= (1 << PB2);    // SS HIGH — deselect slave
}

int main(void) {
    SPI_MasterInit();

    uint8_t seq[] = {85, 170, 255};
    uint8_t i = 0;

    while (1) {
        SPI_Transmit(seq[i]);
        i = (i + 1) % 3;    // cycle 0→1→2→0→...
        _delay_ms(1000);
    }
}
